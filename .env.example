# Flask / Session
FLASK_SECRET_KEY=change-this-secret-key
SESSION_COOKIE_SECURE=0
BILLING_LOGIN_MAX_AGE_SECONDS=604800

# Administrator (Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# ROS7 REST (server pusat)
ROS7_REST_BASE_URL=https://ipserver/rest
ROS7_REST_USERNAME=your-rest-username
ROS7_REST_PASSWORD=your-rest-password
ROS7_REST_TIMEOUT_SECONDS=20
ROS7_REST_VERIFY_SSL=1

# L2TP provisioning
ROS7_L2TP_SECRET_PROFILE=default
ROS7_L2TP_DEFAULT_PASSWORD=1234
ROS7_L2TP_CONNECT_TO=ipserver
ROS7_L2TP_LOCAL_ADDRESS=10.168.0.1
ROS7_L2TP_REMOTE_NETWORK=10.168.0.0/24
ROS7_L2TP_USERNAME_PREFIX=billing

# Proxy remote
WEBFIG_PROXY_HOST=ipserver
WEBFIG_PROXY_PREFIX=6000
ROS7_WEBFIG_TO_PORT=80
ROS7_WEBFIG_DST_ADDRESS=

WINBOX_PROXY_HOST=ipserver
WINBOX_PROXY_PREFIX=7000
ROS7_WINBOX_TO_PORT=8291

# WhatsApp Gateway
ADMIN_WA_NUMBER=628xxxxxxxxxx
WA_GATEWAY_URL=https://wa.example.net/send-message
